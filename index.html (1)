<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SEO Meta Tags -->
    <title>Your Name | Personal Portfolio</title>
    <meta name="description" content="Personal portfolio showcasing skills, projects, experience, and contact information.">
    <meta name="keywords" content="Portfolio, Web Developer, HTML5, CSS, JavaScript">
    <meta name="author" content="Your Name">
    <meta name="robots" content="index, follow">

    <!-- Open Graph -->
    <meta property="og:title" content="Your Name | Personal Portfolio">
    <meta property="og:description" content="Accessible HTML5 Personal Portfolio">
    <meta property="og:type" content="website">

    <style>
        body{
            font-family: Arial, sans-serif;
            margin:0;
            line-height:1.6;
        }

        header,footer{
            background:#333;
            color:#fff;
            text-align:center;
            padding:15px;
        }

        nav ul{
            list-style:none;
            display:flex;
            justify-content:center;
            gap:20px;
            padding:0;
        }

        nav a{
            color:white;
            text-decoration:none;
        }

        main{
            padding:20px;
        }

        section{
            margin-bottom:40px;
        }

        article{
            border:1px solid #ccc;
            padding:15px;
            margin-bottom:15px;
        }

        form{
            max-width:500px;
        }

        label{
            display:block;
            margin-top:15px;
        }

        input,textarea{
            width:100%;
            padding:10px;
            margin-top:5px;
        }

        button{
            margin-top:20px;
            padding:10px 20px;
        }

        .skip-link{
            position:absolute;
            left:-999px;
        }

        .skip-link:focus{
            left:10px;
            top:10px;
            background:yellow;
            padding:10px;
        }
    </style>
</head>

<body>

<a href="#main-content" class="skip-link">Skip to Main Content</a>

<header role="banner">
    <h1>Your Name</h1>

    <nav aria-label="Primary Navigation">
        <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>
</header>

<main id="main-content">

<section id="home" aria-labelledby="home-heading">
    <h2 id="home-heading">Home</h2>
    <p>Welcome to my portfolio. I am a passionate web developer who creates modern, responsive, and accessible websites.</p>
</section>

<section id="about" aria-labelledby="about-heading">
    <h2 id="about-heading">About Me</h2>

    <article>
        <h3>Education</h3>
        <p>B.Tech in Computer Science Engineering.</p>
    </article>

    <article>
        <h3>Skills</h3>
        <ul>
            <li>HTML5</li>
            <li>CSS3</li>
            <li>JavaScript</li>
            <li>Python</li>
        </ul>
    </article>
</section>

<section id="projects" aria-labelledby="projects-heading">
    <h2 id="projects-heading">Projects</h2>

    <article>
        <h3>Portfolio Website</h3>
        <p>A responsive portfolio built using semantic HTML5.</p>
    </article>

    <article>
        <h3>Weather Application</h3>
        <p>A weather app using API integration.</p>
    </article>

    <article>
        <h3>Student Management System</h3>
        <p>A simple CRUD application for managing student records.</p>
    </article>
</section>

<aside aria-label="Additional Information">
    <h2>Achievements</h2>
    <ul>
        <li>Certified Python Programmer</li>
        <li>Completed Web Development Internship</li>
        <li>Participated in Hackathons</li>
    </ul>
</aside>

<section id="contact" aria-labelledby="contact-heading">
    <h2 id="contact-heading">Contact Me</h2>

    <form action="#" method="post">

        <label for="name">Full Name</label>
        <input type="text" id="name" name="name"
               required autocomplete="name"
               aria-required="true">

        <label for="email">Email Address</label>
        <input type="email" id="email" name="email"
               required autocomplete="email"
               aria-required="true">

        <label for="subject">Subject</label>
        <input type="text" id="subject" name="subject">

        <label for="message">Message</label>
        <textarea id="message" name="message"
                  rows="5"
                  required
                  aria-required="true"></textarea>

        <button type="submit">Send Message</button>

    </form>
</section>

</main>

<footer>
    <p>&copy; 2026 Your Name | All Rights Reserved</p>
</footer>

</body>
</html>